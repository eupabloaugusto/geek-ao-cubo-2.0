# Geek ao Cubo — Automation Pipeline
# Renomeie este arquivo para `.env` e preencha com suas credenciais reais.
# NUNCA suba o arquivo `.env` para o repositório (já está no .gitignore).

# ----------------------------------------------------
# GROQ API (Task 3.2 — Panorama Factual)
# Obtenha em: https://console.groq.com/keys
# ----------------------------------------------------
GROQ_API_KEY=gsk_SUA_CHAVE_AQUI

# ----------------------------------------------------
# ANTHROPIC API (Task 3.3 — Editorial Sonnet)
# Obtenha em: https://console.anthropic.com/settings/keys
# ----------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_AQUI

# ----------------------------------------------------
# WORDPRESS REST API (Task 3.4 — Publicador)
# Crie em: WP Admin > Usuários > Seu Perfil > Application Passwords
# ----------------------------------------------------
WP_BASE_URL=https://modomaratona.com
WP_USERNAME=seu_usuario_wp
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ----------------------------------------------------
# WEBHOOK DE ALERTAS (Task 2.2 — Sistema de Alertas)
# Suporte a Discord e Slack. Cole apenas uma das URLs.
# Discord: Servidor > Configuracoes > Integrações > Webhooks
# Slack:   api.slack.com/apps > Incoming Webhooks
# ----------------------------------------------------
# Discord:
# WEBHOOK_URL=https://discord.com/api/webhooks/SEU_ID/SEU_TOKEN
# Slack:
# WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX
WEBHOOK_URL=
